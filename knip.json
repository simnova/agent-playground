{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["turbo.json", "pnpm-workspace.yaml"],
      "project": ["**/*.{js,ts,tsx,json,md}"]
    },
    "apps/staff": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"]
    },
    "apps/public": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"]
    },
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/antd-provider.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": ["**/*.d.ts", "**/src/gql/**", "apps/api/src/graphql/resolvers.types.ts", "apps/api/src/graphql/context.ts"],
  "ignoreBinaries": ["turbo", "func", "biome", "e18e"],
  "ignoreWorkspaces": ["packages/config-typescript"],
  "ignoreDependencies": ["@types/*", "typescript", "@typescript/native-preview", "tailwindcss", "mongodb-memory-server", "@graphql-typed-document-node/core"],
  "ignoreUnresolved": ["vite/client"],
  "typescript": {
    "config": ["tsconfig.json", "apps/*/tsconfig.json", "packages/*/tsconfig.json"]
  }
}
